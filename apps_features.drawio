        <mxCell id="c1_2" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;" value="&lt;b&gt;Content Safety &amp; Safeguarding&lt;/b&gt;&lt;br&gt;• Seizure-safety (flash ≤ 3 Hz)&lt;br&gt;• Scene-script validation gate&lt;br&gt;• Emotional-safety rules&lt;br&gt;• Mandatory human review">
