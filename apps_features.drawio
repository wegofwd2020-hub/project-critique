        <mxCell id="k4" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;" value="&lt;b&gt;Rendering Engines&lt;/b&gt;&lt;br&gt;• Matplotlib stick-figure (v1)&lt;br&gt;• Blender Grease Pencil (v2)&lt;br&gt;• Stable scene-script contract">
          <mxGeometry height="124" width="450" x="510" y="576" as="geometry" />
        </mxCell>
        <mxCell id="k5" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=8;" value="&lt;b&gt;Visual &amp;amp; Brand System&lt;/b&gt;&lt;br&gt;• Kolam-inspired logo&lt;br&gt;• Accessible palette (no red)&lt;br&gt;• Baloo bilingual type (Tamil+Latin)&lt;br&gt;• Child &amp;amp; adult icon sets">
          <mxGeometry height="124" width="450" x="510" y="708" as="geometry" />
        </mxCell>
        <mxCell id="k6" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#eef7ec;strokeColor=#82b366;fontSize=11;arcSize=8;dashed=1;" value="&lt;b&gt;Roadmap (planned)&lt;/b&gt;&lt;br&gt;• Parent intake UI&lt;br&gt;• Multi-actor authoring&lt;br&gt;• First-person narration&lt;br&gt;• Progress-adaptive premises">
          <mxGeometry height="124" width="450" x="510" y="840" as="geometry" />
        </mxCell>

        <!-- ============ COLUMN 3: STUDYBUDDY_SELFLEARNER / MENTIBLE (amber) ============ -->
        <mxCell id="s-head" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#d79b00;strokeColor=#a06800;fontColor=#ffffff;fontSize=12;arcSize=8;" value="&lt;b&gt;STUDYBUDDY_SELFLEARNER (Mentible)&lt;/b&gt;&lt;br&gt;Scoped query → publishable EPUB3 / PDF book&lt;br&gt;&lt;i&gt;Audience: adult self-learners &amp;amp; professionals (BYOK)&lt;/i&gt;&lt;br&gt;Stage: authoring + export shipped; accounts in flight">
