        <mxCell id="s3" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;arcSize=8;" value="&lt;b&gt;Artifact Compilation &amp;amp; Export&lt;/b&gt;&lt;br&gt;• EPUB3 (MathML + SVG, offline)&lt;br&gt;• Textbook-layout PDF&lt;br&gt;• Editorial covers&lt;br&gt;• Mermaid→SVG · KaTeX→MathML">
