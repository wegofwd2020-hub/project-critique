        <mxCell id="title" parent="1" vertex="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;" value="WeGoFwd2020 applications — feature overview (3 apps, 3 audiences) · 2026-07-07">
          <mxGeometry height="30" width="1000" x="30" y="20" as="geometry" />
        </mxCell>
        <mxCell id="h0" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#6c8ebf;strokeColor=#3c5a80;fontColor=#ffffff;fontSize=12;arcSize=8;" value="&lt;b&gt;PRAMANA&lt;/b&gt;&lt;br&gt;Audit-grade compliance training &amp; evidence&lt;br&gt;&lt;i&gt;Audience: compliance officers · regulated enterprises&lt;/i&gt;&lt;br&gt;Stage: backend + content pipeline live; assignment / cert runtime pending (SOX v1)">
          <mxGeometry height="96" width="450" x="30" y="70" as="geometry" />
        </mxCell>
        <mxCell id="c0_0" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=8;" value="&lt;b&gt;Course &amp; Content&lt;/b&gt;&lt;br&gt;• Course versioning&lt;br&gt;• AI-drafted, human-approved content&lt;br&gt;• In-process quiz generation&lt;br&gt;• Approval state machine + SoD">
          <mxGeometry height="106" width="450" x="30" y="178" as="geometry" />
        </mxCell>
        <mxCell id="c0_1" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=8;" value="&lt;b&gt;Content Supply Chain&lt;/b&gt;&lt;br&gt;• Mentible package ingest (signed / hashed)&lt;br&gt;• Content commissioning (package request)&lt;br&gt;• Compliance video draft (wegofwd-video)&lt;br&gt;• Quarantine-until-approved">
          <mxGeometry height="106" width="450" x="30" y="292" as="geometry" />
        </mxCell>
        <mxCell id="c0_2" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=8;" value="&lt;b&gt;Assignment &amp; Delivery&lt;/b&gt;&lt;br&gt;• Assignment state machine (domain)&lt;br&gt;• Configurable cooldowns&lt;br&gt;• Multi-attempt quiz (max 2)&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ Manual + bulk-CSV assign (planned)&lt;/font&gt;">
          <mxGeometry height="106" width="450" x="30" y="406" as="geometry" />
        </mxCell>
        <mxCell id="c0_3" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#eef3fb;strokeColor=#6c8ebf;fontSize=11;arcSize=8;dashed=1;" value="&lt;b&gt;Certification&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ PDF certificates (planned)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ Self-attestation (planned)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ Public verification code (planned)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ Expiry tied to cooldown (planned)&lt;/font&gt;">
          <mxGeometry height="106" width="450" x="30" y="520" as="geometry" />
        </mxCell>
        <mxCell id="c0_4" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=8;" value="&lt;b&gt;Audit &amp; Evidence&lt;/b&gt;&lt;br&gt;• Append-only audit log&lt;br&gt;• Tamper-evident hash chain&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ 7-year retention (policy)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ S3 Object-Lock archive (v2)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ Auditor evidence export (planned)&lt;/font&gt;">
          <mxGeometry height="124" width="450" x="30" y="634" as="geometry" />
        </mxCell>
        <mxCell id="c0_5" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=8;" value="&lt;b&gt;Roles &amp; Identity&lt;/b&gt;&lt;br&gt;• 5 roles (Trainee → Auditor)&lt;br&gt;• OIDC SSO + first-login provisioning&lt;br&gt;• Separation of duties (content path)&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ SAML SSO (planned)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ GDPR right-to-erasure (planned)&lt;/font&gt;">
          <mxGeometry height="124" width="450" x="30" y="766" as="geometry" />
        </mxCell>
        <mxCell id="c0_6" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;arcSize=8;" value="&lt;b&gt;Frameworks &amp; Stories&lt;/b&gt;&lt;br&gt;• SOX — v1 target (single-tenant)&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ FCPA — first GRC backlog (11 stories)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ HIPAA · GDPR · ISO 27001 · PCI (future)&lt;/font&gt;&lt;br&gt;• Framework-native user-story library">
