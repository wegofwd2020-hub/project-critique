        <mxCell id="c2_1" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;arcSize=8;" value="&lt;b&gt;Multi-Provider LLM &amp; Billing&lt;/b&gt;&lt;br&gt;• Anthropic + OpenAI / Groq / OpenRouter / Gemini&lt;br&gt;• Per-request BYOK passthrough&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ Managed-key vault (built, off)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ Server metering + spend caps (off)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#9a9a9a&quot;&gt;◦ RevenueCat entitlements (off)&lt;/font&gt;">
