        <mxCell id="h1" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#82b366;strokeColor=#4f7a2f;fontColor=#ffffff;fontSize=12;arcSize=8;" value="&lt;b&gt;KATHAI CHITHIRAM&lt;/b&gt;&lt;br&gt;Parent's story → calm captioned animation&lt;br&gt;&lt;i&gt;Audience: parents / therapists author · special-needs children view&lt;/i&gt;&lt;br&gt;Stage: prototype — renderers, audio, safety, accounts &amp; feedback wired">
