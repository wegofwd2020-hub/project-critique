        <mxCell id="s4" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;arcSize=8;" value="&lt;b&gt;Templates &amp;amp; Theming&lt;/b&gt;&lt;br&gt;• Versioned BookTemplates&lt;br&gt;• Brand design tokens&lt;br&gt;• Cover motifs&lt;br&gt;• Glossary &amp;amp; front-matter">
