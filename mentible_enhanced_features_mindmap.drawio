="1" as="geometry" /></mxCell><mxCell id="e2_r10" parent="1" edge="1" source="root2" target="g2_10" style="edgeStyle=entityRelationEdgeStyle;curved=1;startArrow=none;endArrow=none;rounded=0;strokeColor=#82b366;strokeWidth=1.5;dashed=1;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="g2_11" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#a9d18e;strokeColor=#82b366;fontSize=11;fontStyle=1;arcSize=20;dashed=1;fontColor=#1a3d1a;" value="Content Currency&lt;br&gt;Agent&lt;br&gt;&lt;font style=&quot;font-size:8px&quot;&gt;(ADR-030 Proposed · ZERO CODE)&lt;/font&gt;"><mxGeometry height="54" width="190" x="480" y="900" as="geometry" /></mxCell><mxCell id="l2_11_0" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacingLeft=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=20;dashed=1;fontColor=#1a5c1a;" value="Watch manifest derived at publish"><mxGeometry height="24" width="280" x="140" y="840" as="geometry" /></mxCell><mxCell id="e2_gg2_11_0" parent="1" edge="1" source="g2_11" target="l2_11_0" style="edgeStyle=entityRelationEdgeStyle;curved=1;startArrow=none;endArrow=none;rounded=0;strokeColor=#82b366;strokeWidth=1.5;dashed=1;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="l2_11_1" parent="1" vertex="1" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacingLeft=6;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;arcSize=20;dashed=1;fontColor=#1a5c1a;" value="Author-run check on BYOK — proposes, never edits"><mxGeometry height="24" width="280" x="140" y="868" as="geometry" /></mxCell><mxCell id="e2_gg2_11_1" parent="1" edge="1" source="g2_11" target="l2_11_1" style="edgeStyle=entityRelationEdgeStyle;curved=1;startArrow=none;endArrow=none;rounded=0;strokeColor=#82b366;strokeWidth=1.5;dashed=1;"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="l2_11_2" parent="1" vertex="1" style="rounded=1;whi